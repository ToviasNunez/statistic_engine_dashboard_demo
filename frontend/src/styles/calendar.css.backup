/* Elegant Professional Calendar */
.modern-calendar-container {
  position: relative;
  width: 100.react-calendar__month-view__weekdays__weekday {
  text-align: center;
  padding: 0.75rem 0;
  font-size: 0.75rem;
  font-weight: 600;
  color: #9ca3af;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  background: none !important;
  border: none !important;
}idth: 320px;
  height: auto;
  background: #ffffff;
  border-radius: 16px;
  padding: 20px;
  border: 1px solid #e2e8f0;
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

.modern-calendar-container:hover {
  /* No size changing effects */
}

.modern-calendar-glow {
  display: none;
}

.modern-calendar-container:hover .modern-calendar-glow {
  display: none;
}

.modern-calendar-inner {
  position: relative;
  z-index: 10;
}



/* Calendar Component Styles */
.modern-calendar {
  width: 100%;
  background: transparent;
  border: none;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
}

/* Navigation Header */
.modern-calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1rem;
  padding: 0 0.25rem;
}

.modern-calendar-nav-btn {
  width: 2rem;
  height: 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0.5rem;
  transition: all 0.2s;
  background: rgba(255, 255, 255, 0.8);
  border: 1px solid rgba(229, 231, 235, 0.5);
  color: #4b5563;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  backdrop-filter: blur(10px);
  cursor: pointer;
}

.modern-calendar-nav-btn:hover {
  background: white;
  color: #111827;
  box-shadow: 0 6px 10px -2px rgba(0, 0, 0, 0.15);
  transform: scale(1.05);
  border-color: #9ca3af;
}

.modern-calendar-title {
  text-align: center;
}

.month-name {
  display: block;
  font-size: 1rem;
  font-weight: bold;
  color: #1f2937;
  background: linear-gradient(135deg, #4f46e5, #7c3aed, #9333ea);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
}

.year-number {
  display: block;
  font-size: 0.75rem;
  font-weight: 600;
  color: #4b5563;
  margin-top: 0.125rem;
}

/* Month View */
.react-calendar__month-view {
  width: 100%;
}

/* Days of Week Header */
.react-calendar__month-view__weekdays {
  margin-bottom: 0.5rem;
}

.react-calendar__month-view__weekdays__weekday {
  text-align: center;
  padding: 0.15rem 0;
  font-size: 0.6rem;
  font-weight: 600;
  color: #D95C12;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  background: none !important;
  border: none !important;
}

/* Days Grid */
.react-calendar__month-view__days {
  display: grid !important;
  grid-template-columns: repeat(7, 36px) !important;
  gap: 4px !important;
  justify-content: center !important;
  width: 100% !important;
  padding: 0.5rem 0 !important;
}

/* Individual Day Tiles */
.react-calendar__tile {
  position: relative;
  height: 36px !important;
  width: 36px !important;
  max-width: 36px !important;
  min-width: 36px !important;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.875rem;
  font-weight: 500;
  border-radius: 8px;
  transition: all 0.15s ease;
  cursor: pointer;
  border: none;
  background: transparent !important;
  color: #374151;
  margin: 1px !important;
  flex-shrink: 0 !important;
  flex-grow: 0 !important;
}

.modern-calendar-tile {
  width: 36px !important;
  height: 36px !important;
  color: #374151;
  font-weight: 500;
  background: transparent !important;
  border: none;
  border-radius: 8px;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  flex-shrink: 0;
  flex-grow: 0;
  font-size: 0.875rem !important;
  cursor: pointer;
  transition: all 0.15s ease;
}

.modern-calendar-tile:hover {
  background: #f8f9fa !important;
  color: #D95C12 !important;
  font-weight: 600;
}

/* Today */
.modern-calendar-today {
  color: #ffffff !important;
  font-weight: 600;
  background: #D95C12 !important;
  border: none !important;
  width: 36px !important;
  height: 36px !important;
}

/* Range Selection - Clean and Professional */
.modern-calendar-range {
  color: #ffffff !important;
  font-weight: 600;
  background: rgba(217, 92, 18, 0.1) !important;
  border: none !important;
  width: 36px !important;
  height: 36px !important;
}

.modern-calendar-range-endpoint {
  color: #ffffff !important;
  font-weight: 600;
  background: #D95C12 !important;
  border: none !important;
  width: 36px !important;
  height: 36px !important;
}

/* Disabled/Other Month */
.react-calendar__month-view__days__day--neighboringMonth {
  color: #d1d5db !important;
  background: transparent !important;
  font-weight: 400;
}

.react-calendar__month-view__days__day--neighboringMonth:hover {
  background: #f9fafb !important;
  color: #9ca3af !important;
}

/* Animation */
.modern-calendar-container.animating .react-calendar__month-view {
  transition: all 0.3s;
  animation: fadeInSlide 0.3s ease-out;
}

@keyframes fadeInSlide {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}



/* Override default react-calendar styles */
.react-calendar,
.react-calendar *,
.react-calendar *:before,
.react-calendar *:after {
  box-sizing: border-box;
}

.react-calendar {
  width: 100% !important;
  background: transparent !important;
  border: none !important;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
}

/* Style the standard ReactCalendar navigation */
.react-calendar__navigation {
  display: flex !important;
  height: 40px !important;
  margin-bottom: 1.5rem !important;
  align-items: center !important;
}

.react-calendar__navigation button {
  min-width: 40px !important;
  max-width: 40px !important;
  width: 40px !important;
  height: 40px !important;
  background: transparent !important;
  border: 1px solid #e2e8f0 !important;
  border-radius: 8px !important;
  color: #6b7280 !important;
  font-weight: 500 !important;
  font-size: 0.875rem !important;
  transition: all 0.15s ease !important;
  margin: 0 4px !important;
  flex-shrink: 0 !important;
}

.react-calendar__navigation button:hover {
  background: #f8f9fa !important;
  color: #D95C12 !important;
  border-color: #D95C12 !important;
  font-weight: 600 !important;
}

.react-calendar__navigation button:disabled {
  background: rgba(255, 255, 255, 0.4) !important;
  color: #9ca3af !important;
  cursor: not-allowed !important;
  transform: none !important;
}

.react-calendar__navigation__label {
  flex-grow: 1 !important;
  color: #1f2937 !important;
  font-weight: 600 !important;
  font-size: 1.125rem !important;
  cursor: pointer !important;
  text-align: center !important;
}

.react-calendar__navigation__label:hover {
  color: #B8470F !important;
}

.react-calendar__navigation__arrow {
  font-size: 1.2rem !important;
  font-weight: bold !important;
}

.react-calendar button {
  margin: 0 !important;
  border: none !important;
  outline: none !important;
}

.react-calendar button:enabled:hover,
.react-calendar button:enabled:focus {
  background: none !important;
}

.react-calendar__tile:hover {
  background: #f8f9fa !important;
  color: #D95C12 !important;
  font-weight: 600 !important;
}

/* Clean active styles */
.react-calendar__tile--active {
  background: #D95C12 !important;
  color: #ffffff !important;
  font-weight: 600 !important;
}

.react-calendar__tile--hasActive {
  background: #D95C12 !important;
  color: #ffffff !important;
}

.react-calendar__tile--range {
  background: none !important;
}

.react-calendar__tile--rangeStart {
  background: none !important;
}

.react-calendar__tile--rangeEnd {
  background: none !important;
}



/* Year View Styles */
.react-calendar__year-view {
  width: 100%;
}

.react-calendar__year-view__months {
  display: grid !important;
  grid-template-columns: repeat(3, 1fr) !important;
  gap: 0.5rem !important;
}

.react-calendar__year-view__months__month {
  position: relative;
  height: 48px !important;
  width: 80px !important;
  max-width: 80px !important;
  min-width: 80px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  font-size: 0.875rem !important;
  font-weight: 600 !important;
  border-radius: 8px !important;
  transition: background-color 0.2s, color 0.2s !important;
  cursor: pointer !important;
  border: 1px solid #F0B400 !important;
  background: #FFFFFF !important;
  color: #D95C12 !important;
  margin: 2px !important;
  flex-shrink: 0 !important;
  flex-grow: 0 !important;
}

.react-calendar__year-view__months__month:hover {
  background: #FFF4CC !important;
  border-color: #D95C12 !important;
  color: #B8470F !important;
  font-weight: 700 !important;
}

/* Decade View Styles */
.react-calendar__decade-view {
  width: 100%;
}

.react-calendar__decade-view__years {
  display: grid !important;
  grid-template-columns: repeat(3, 1fr) !important;
  gap: 0.5rem !important;
}

.react-calendar__decade-view__years__year {
  position: relative;
  height: 48px !important;
  width: 80px !important;
  max-width: 80px !important;
  min-width: 80px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  font-size: 0.875rem !important;
  font-weight: 600 !important;
  border-radius: 8px !important;
  transition: background-color 0.2s, color 0.2s !important;
  cursor: pointer !important;
  border: 1px solid #F0B400 !important;
  background: #FFFFFF !important;
  color: #D95C12 !important;
  margin: 2px !important;
  flex-shrink: 0 !important;
  flex-grow: 0 !important;
}

.react-calendar__decade-view__years__year:hover {
  background: #FFF4CC !important;
  border-color: #D95C12 !important;
  color: #B8470F !important;
  font-weight: 700 !important;
}

/* Clean professional design without excessive animations */

/* Responsive adjustments */
@media (max-width: 640px) {
  .modern-calendar-container {
    padding: 16px;
    border-radius: 20px;
  }
  
  .react-calendar__tile {
    height: 40px !important;
    font-size: 12px !important;
  }
  
  .react-calendar__year-view__months__month,
  .react-calendar__decade-view__years__year {
    height: 2.5rem !important;
    font-size: 0.75rem !important;
  }
}
